@page
@model MiProyectoWeb.Pages.DashboardModel
@{
    ViewData["Title"] = "Panel de Control";
}

<div class="container mt-4">
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger text-center">⚠️ @Model.ErrorMessage</div>
    }

    @if (Model.Rol == "Admin")
    {
        <div class="row">
            <div class="col-md-5">
                <div class="card shadow border-0">
                    <div class="card-header bg-dark text-white fw-bold">Registrar Alimento (Con Validación Server-Side)</div>
                    <div class="card-body">
                        <form method="post" asp-page-handler="AgregarProductoAdmin">
                            
                            <div class="mb-3">
                                <label class="form-label fw-bold text-danger">Cédula del Proveedor (Dato Sensible - Validado en Servidor)</label>
                                <input type="text" asp-for="CedulaProveedor" class="form-control" placeholder="Ej: 1726354890" required />
                                <div class="form-text text-muted">Se validará mediante algoritmo de la base de datos fiscal en el backend.</div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Categoría del Producto</label>
                                <select id="ddlCategoria" asp-for="CategoriaSeleccionada" class="form-select" required>
                                    <option value="">-- Seleccione una Categoría --</option>
                                    @foreach (var cat in Model.Categorias)
                                    {
                                        <option value="@cat">@cat</option>
                                    }
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Subcategoría / Marca Relacionada</label>
                                <select id="ddlSubcategoria" asp-for="SubcategoriaSeleccionada" class="form-select" required disabled>
                                    <option value="">-- Primero seleccione una Categoría --</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Especificación del Nombre</label>
                                <input type="text" asp-for="NuevoNombre" class="form-control" placeholder="Ej: Funda Mediana" required />
                            </div>

                            <div class="row">
                                <div class="col-6 mb-3">
                                    <label class="form-label fw-bold">Precio ($)</label>
                                    <input type="number" step="0.01" asp-for="NuevoPrecio" class="form-control" required />
                                </div>
                                <div class="col-6 mb-3">
                                    <label class="form-label fw-bold">Stock</label>
                                    <input type="number" asp-for="NuevoStock" class="form-control" required />
                                </div>
                            </div>

                            <button type="submit" class="btn btn-success w-100 fw-bold">Guardar en Base de Datos</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.getElementById("ddlCategoria").addEventListener("change", async function() {
            const categoria = this.value;
            const ddlSub = document.getElementById("ddlSubcategoria");
            
            ddlSub.innerHTML = '<option value="">Cargando opciones...</option>';
            ddlSub.disabled = true;

            if (!categoria) {
                ddlSub.innerHTML = '<option value="">-- Primero seleccione una Categoría --</option>';
                return;
            }

            try {
                // Petición al Handler HTTP Get de Razor Pages
                const response = await fetch(`?handler=Subcategorias&categoria=${encodeURIComponent(categoria)}`);
                const data = await response.json();

                ddlSub.innerHTML = '<option value="">-- Seleccione Subcategoría --</option>';
                data.forEach(item => {
                    const opt = document.createElement("option");
                    opt.value = item;
                    opt.textContent = item;
                    ddlSub.appendChild(opt);
                });
                ddlSub.disabled = false;
            } catch (error) {
                console.error("Error al obtener subcategorías:", error);
                ddlSub.innerHTML = '<option value="">Error al cargar datos</option>';
            }
        });
    </script>
}